{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-1",
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "secrets/**": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/credentials.json": "deny",
      "**/*credentials*.json": "deny",
      "**/*secret*.json": "deny",
      ".npmrc": "deny",
      ".netrc": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "**/.zsh_secrets/**": "deny"
    },
    "bash": {
      "*": "allow",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny"
    }
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ],
      "enabled": true
    }
  }
}
