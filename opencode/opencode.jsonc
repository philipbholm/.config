{
  "$schema": "https://opencode.ai/config.json",

  // Sample global OpenCode config.
  // This file is safe to commit if secrets stay in env vars/files.
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "autoupdate": "notify",
  "share": "manual",

  // Load repository guidance into prompts.
  "instructions": [
    "{file:~/.config/CLAUDE.md}",
    "./CLAUDE.local.md"
  ],

  // Conservative global defaults; can be overridden per agent.
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },

  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow"
        }
      }
    }
  },

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ],
      "enabled": true
    }
  },

  // Example plugin setup (already present in package.json).
  "plugin": [
    "@opencode-ai/plugin"
  ]
}
