prefix_rule(pattern=["git", "push", "--force"], decision="deny")
prefix_rule(pattern=["git", "push", "--force-with-lease"], decision="deny")
prefix_rule(pattern=["git", "push", "-f"], decision="deny")
prefix_rule(pattern=["git", "reset", "--hard"], decision="deny")
prefix_rule(pattern=["git", "clean", "-fd"], decision="deny")
prefix_rule(pattern=["git", "clean", "-xdf"], decision="deny")
prefix_rule(pattern=["rm", "-rf"], decision="deny")
prefix_rule(pattern=["rm", "-fr"], decision="deny")
prefix_rule(pattern=["sudo"], decision="deny")
prefix_rule(pattern=["dd"], decision="deny")
prefix_rule(pattern=["mkfs"], decision="deny")
prefix_rule(pattern=["diskutil", "eraseDisk"], decision="deny")
prefix_rule(pattern=["diskutil", "partitionDisk"], decision="deny")
prefix_rule(pattern=["chmod", "-R", "777"], decision="deny")
prefix_rule(pattern=["chown", "-R"], decision="deny")
prefix_rule(pattern=["npm", "run", "docker-up:test"], decision="allow")
prefix_rule(pattern=["npm", "--version"], decision="allow")
prefix_rule(pattern=["echo", "$PATH"], decision="allow")
